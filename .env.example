# ─────────────────────────────────────────────────────────────────────────────
# AgentOS — Environment Variables
#
# Copy this file to .env and fill in your values.
# Lines starting with # are comments; leave them as-is for reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: groq (free) or openai
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile   # Groq model name; or gpt-4o-mini for OpenAI

# Groq (free tier — https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# ── Web Search ────────────────────────────────────────────────────────────────
# DuckDuckGo requires no key. Tavily is a fallback (1000 free credits/month).
# Sign up at https://app.tavily.com — optional but recommended.
TAVILY_API_KEY=tvly-your_tavily_api_key_here   # optional

# ── Qdrant (Vector DB) ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_EPISODIC=episodic_memory
QDRANT_COLLECTION_KNOWLEDGE=knowledge_cache

# ── Redis (Cache + Session Store) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600       # Cache TTL for research results (1 hour)

# ── LangSmith (Observability) ─────────────────────────────────────────────────
# Optional — tracing is disabled when this key is absent.
# Sign up at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your_langsmith_api_key_here
# LANGCHAIN_PROJECT=agentos

# ── Agent Tuning ──────────────────────────────────────────────────────────────
MAX_CRITIC_RETRIES=2         # How many times the critic can send work back
SEARCH_RESULTS_PER_TASK=5   # Web results fetched per planner sub-task
RETRIEVAL_TOP_K=3            # Episodic memories recalled per query
CODE_EXEC_TIMEOUT=10         # Seconds before a code snippet is killed
